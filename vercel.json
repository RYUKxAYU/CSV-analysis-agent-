{
  "$schema": "https://openapi.vercel.com/schemas/project.json",
  "framework": null,
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt",
  "devCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}